{
  "name": "cersai",
  "displayName": "Cersai - CERT-C AI Analyzer",
  "description": "AI-powered triage of CERT-C, MISRA C, and QAC static analysis warnings. Reads an Excel report, analyzes each warning against your source code using GitHub Copilot, and writes back priority classifications with detailed justifications.",
  "version": "0.1.0",
  "publisher": "srijithkariyattil",
  "license": "MIT",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "CERT-C",
    "MISRA",
    "QAC",
    "static analysis",
    "embedded",
    "C",
    "code quality",
    "AI",
    "Copilot",
    "triage"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/srijithkpgit/cersai"
  },
  "bugs": {
    "url": "https://github.com/srijithkpgit/cersai/issues"
  },
  "homepage": "https://github.com/srijithkpgit/cersai#readme",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "certcAnalyzer",
          "title": "Cersai",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "certcAnalyzer": [
        {
          "type": "webview",
          "id": "certcAnalyzer.sidebar",
          "name": "Cersai"
        }
      ]
    },
    "commands": [
      {
        "command": "certcAnalyzer.startAnalysis",
        "title": "Cersai: Start Analysis"
      },
      {
        "command": "certcAnalyzer.cancelAnalysis",
        "title": "Cersai: Cancel Analysis"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.91.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
